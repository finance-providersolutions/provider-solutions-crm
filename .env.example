# Provider Solutions CRM — environment variables
#
# Phase 1 NOTE: The Supabase URL and publishable key are also
# hardcoded in `src/api/supabase.js` so the app works without an .env
# file. The publishable key is safe to ship to the browser because
# Row Level Security is enabled on every table (see
# supabase/migrations/0001_initial.sql).
#
# This file exists to document the variables in case you'd rather
# read them from the environment, or for tooling (Vercel/Netlify
# imports, etc.). To use them, copy this file to `.env` and update
# `src/api/supabase.js` to read from import.meta.env instead.

# Supabase project URL (looks like https://<ref>.supabase.co)
SUPABASE_URL=https://ztbadmaufcpkinnjztxy.supabase.co

# Publishable / "anon" key. Safe in the browser when RLS is on.
# NEVER put the secret key (sb_secret_...) in this file.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_JrJwv7ZXLv0PlJcWFtriBQ_JGQwynbE
